# Database — use Neon PostgreSQL on Netlify (https://neon.tech)
# Leave empty for local SQLite (data.db)
DATABASE_URI=

# Required — generate: openssl rand -hex 32
PAYLOAD_SECRET=change-me-in-production

# Admin login (created automatically on first server start if user does not exist)
ADMIN_EMAIL=fusionsamz@gmail.com
ADMIN_PASSWORD=your-secure-password-here

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
